# Copy to .env and source it (or export manually) for standalone `go run` use.
# docker-compose.yml sets these directly and does not read this file.

MASTERS_FILE=configs/masters.json
ROUTING_FILE=configs/routing.json
INSTANCES_FILE=configs/instances.json

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

DEDUP_WINDOW=300s
POLL_INTERVAL=30s
HTTP_TIMEOUT=10s

METRICS_ADDR=:9090
LOG_LEVEL=info

# Phase 2 — remediation worker (remediation/worker.py)
REMEDIATION_MODE=dry-run
BREAKER_WINDOW_SECONDS=1800
AWS_REGION=us-east-1
