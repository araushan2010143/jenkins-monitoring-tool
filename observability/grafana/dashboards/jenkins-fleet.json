{
  "uid": "jenkins-fleet",
  "title": "Jenkins Fleet Observability",
  "tags": ["jenkins", "self-healing"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agent Fleet Status",
      "description": "sum(jenkins_node_online_status) by (node) -- red when a node's status drops below 1 (offline).",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(jenkins_node_online_status) by (node)", "legendFormat": "{{node}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "title": "Queue Backlog Size",
      "description": "jenkins_queue_size -- warning when the build queue exceeds 15.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "jenkins_queue_size", "legendFormat": "queue", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 15 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "System Memory Usage",
      "description": "jenkins_node_mem_used_percent -- warning above 85% (stand-in for a node_exporter metric; see README).",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "jenkins_node_mem_used_percent", "legendFormat": "{{node}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 85 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Disk Capacity Profile",
      "description": "jenkins_node_disk_free_bytes -- warning below 5 GiB free (stand-in for a node_exporter metric; see README).",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "jenkins_node_disk_free_bytes", "legendFormat": "{{node}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 5368709120 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "title": "Observer Health",
      "description": "Phase 1 observer metrics (internal/metrics): alerts sent/suppressed and poll errors.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "jenkins_observer_alerts_sent_total", "legendFormat": "alerts sent", "refId": "A" },
        { "expr": "jenkins_observer_alerts_suppressed_total", "legendFormat": "alerts suppressed", "refId": "B" },
        { "expr": "jenkins_observer_poll_errors_total", "legendFormat": "poll errors", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      }
    }
  ]
}
